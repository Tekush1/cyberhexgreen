import React, { useState, useEffect, useCallback, useRef } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import {
  Search, Filter, Calendar, User, Eye, MessageCircle, Heart,
  Share2, BookOpen, AlertTriangle, Shield, TrendingUp, Clock,
  Tag, Plus, ChevronRight, X, ArrowUp, Bookmark, Send,
  ChevronLeft, Loader2, Wifi, WifiOff, LayoutGrid, LayoutList,
