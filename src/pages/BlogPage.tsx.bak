// ─── Helpers ──────────────────────────────────────────────────────────────────
const fmt = (d: string) => new Date(d).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
const fmtNum = (n: number) => n >= 1000 ? `${(n / 1000).toFixed(1)}k` : String(n);

// ─── Sub-components ───────────────────────────────────────────────────────────
const CategoryIcon = ({ name }: { name: string }) => {
  const m: Record<string, React.ReactNode> = {
    'Scam Alert': <AlertTriangle size={14} />, 'Malware Analysis': <Shield size={14} />,
    'Fraud Investigation': <Search size={14} />, 'Social Engineering': <User size={14} />,
    'Email Security': <Newspaper size={14} />, 'CTF Writeups': <Zap size={14} />,
    'News & Updates': <Newspaper size={14} />,
  };
  return <>{m[name] ?? <BookOpen size={14} />}</>;
};

